# ============================================
# AETHER HUB - Environment Variables
# ============================================

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# Database (Supabase/PostgreSQL)
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/aether_hub?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# AI Provider API Keys
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...

# ============================================
# Stripe Configuration
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription Price IDs
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# Points Package Price IDs
STRIPE_POINTS_SMALL_PRICE_ID=price_...
STRIPE_POINTS_MEDIUM_PRICE_ID=price_...
STRIPE_POINTS_LARGE_PRICE_ID=price_...
STRIPE_POINTS_XLARGE_PRICE_ID=price_...

# ============================================
# Security
# ============================================
# Generate a random 32-byte hex string: openssl rand -hex 32
NEXTAUTH_SECRET=your-secret-key-here
